###############################################################################
# 在线书店 — 完整业务流程测试（Happy Path）
#
# 按顺序执行以下请求：
#   1. 注册客户
#   2. 上架两个商品
#   3. 下单购买
#   4. 查询订单
#   5. 修改客户信息
#   6. 验证库存扣减
#
# 执行方式：
#   用 IntelliJ IDEA 按顺序点击每个请求的绿色运行按钮，
#   将前一步返回的 id 填入后续请求中
###############################################################################

@baseUrl = http://localhost:8080


# ================================================================
# 第一步：注册客户
# ================================================================
POST {{baseUrl}}/api/customers
Content-Type: application/json

{
  "username": "booklover",
  "password": "password123",
  "email": "booklover@example.com",
  "phone": "13888888888",
  "address": "广东省深圳市南山区"
}

# 返回示例：{ "id": 1, "username": "booklover", ... }
# 👆 记下 id，作为后面的 customerId


# ================================================================
# 第二步：上架商品 1 - 《Java并发编程实战》
# ================================================================
POST {{baseUrl}}/api/products
Content-Type: application/json

{
  "name": "Java并发编程实战",
  "description": "Java并发编程领域圣经级著作",
  "price": 89.00,
  "stock": 200,
  "category": "计算机",
  "author": "Brian Goetz",
  "isbn": "978-7-111-37004"
}

# 返回示例：{ "id": 1, "name": "Java并发编程实战", "stock": 200, ... }
# 👆 记下 id，作为第一个 productId


# ================================================================
# 第三步：上架商品 2 - 《重构》
# ================================================================
POST {{baseUrl}}/api/products
Content-Type: application/json

{
  "name": "重构：改善既有代码的设计",
  "description": "Martin Fowler经典之作",
  "price": 69.00,
  "stock": 100,
  "category": "计算机",
  "author": "Martin Fowler",
  "isbn": "978-7-115-51007-7"
}

# 返回示例：{ "id": 2, "name": "重构：改善既有代码的设计", "stock": 100, ... }
# 👆 记下 id，作为第二个 productId


# ================================================================
# 第四步：下单购买（客户1，购买2本Java并发和1本重构）
#   总价 = 89 * 2 + 69 * 1 = 247.00
# ================================================================
POST {{baseUrl}}/api/orders
Content-Type: application/json

{
  "customerId": 1,
  "items": [
    {
      "productId": 1,
      "quantity": 2
    },
    {
      "productId": 2,
      "quantity": 1
    }
  ]
}

# 返回示例：
# {
#   "id": 1,
#   "orderNumber": "ORD17181234560001",
#   "customerId": 1,
#   "totalAmount": 247.00,
#   "status": "PENDING",
#   "items": [...]
# }
# 👆 记下 id 和 orderNumber


# ================================================================
# 第五步：按订单ID查询订单
# ================================================================
GET {{baseUrl}}/api/orders/1


# ================================================================
# 第六步：按订单号查询订单
# ================================================================
GET {{baseUrl}}/api/orders/number/ORD17181234560001


# ================================================================
# 第七步：按客户ID查询所有订单
# ================================================================
GET {{baseUrl}}/api/orders?customerId=1


# ================================================================
# 第八步：修改客户信息
# ================================================================
PUT {{baseUrl}}/api/customers/1
Content-Type: application/json

{
  "email": "newemail@example.com",
  "phone": "13899999999",
  "address": "浙江省杭州市西湖区"
}


# ================================================================
# 第九步：查询客户确认修改
# ================================================================
GET {{baseUrl}}/api/customers/1


# ================================================================
# 第十步：校验库存扣减
#   Java并发 - 200库存 - 2 = 198
#   重构 - 100库存 - 1 = 99
# ================================================================
GET {{baseUrl}}/api/products/1
# 期望 stock = 198

GET {{baseUrl}}/api/products/2
# 期望 stock = 99
