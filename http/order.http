@baseUrl = http://localhost:8080

### 1. 下单 - 成功 (201 Created)
# 请将 customerId 和 productId 替换为实际的 id
POST {{baseUrl}}/api/orders
Content-Type: application/json

{
  "customerId": 1,
  "items": [
    {
      "productId": 1,
      "quantity": 2
    },
    {
      "productId": 2,
      "quantity": 1
    }
  ]
}

### 2. 下单 - 订单明细为空 (400 Bad Request)
POST {{baseUrl}}/api/orders
Content-Type: application/json

{
  "customerId": 1,
  "items": []
}

### 3. 下单 - 客户ID为空 (400 Bad Request)
POST {{baseUrl}}/api/orders
Content-Type: application/json

{
  "customerId": null,
  "items": [
    {
      "productId": 1,
      "quantity": 1
    }
  ]
}

### 4. 下单 - 客户不存在 (404 Not Found)
POST {{baseUrl}}/api/orders
Content-Type: application/json

{
  "customerId": 99999,
  "items": [
    {
      "productId": 1,
      "quantity": 1
    }
  ]
}

### 5. 下单 - 商品不存在 (404 Not Found)
POST {{baseUrl}}/api/orders
Content-Type: application/json

{
  "customerId": 1,
  "items": [
    {
      "productId": 99999,
      "quantity": 1
    }
  ]
}

### 6. 下单 - 库存不足 (409 Conflict)
# 将 productId 替换为库存较少的商品 id
POST {{baseUrl}}/api/orders
Content-Type: application/json

{
  "customerId": 1,
  "items": [
    {
      "productId": 2,
      "quantity": 99999
    }
  ]
}

### 7. 下单 - 购买数量为0 (400 Bad Request)
POST {{baseUrl}}/api/orders
Content-Type: application/json

{
  "customerId": 1,
  "items": [
    {
      "productId": 1,
      "quantity": 0
    }
  ]
}

### 8. 查询订单 - 按ID (200 OK)
# 将 1 替换为下单成功后返回的 id
GET {{baseUrl}}/api/orders/1

### 9. 查询订单 - 按ID不存在 (404 Not Found)
GET {{baseUrl}}/api/orders/99999

### 10. 查询订单 - 按订单号 (200 OK)
# 将 ORD1234567890000 替换为实际返回的 orderNumber
GET {{baseUrl}}/api/orders/number/ORD1234567890000

### 11. 查询订单 - 按订单号不存在 (404 Not Found)
GET {{baseUrl}}/api/orders/number/NOT-EXIST

### 12. 查询订单 - 按客户ID (200 OK)
# 将 1 替换为实际客户 id
GET {{baseUrl}}/api/orders?customerId=1

### 13. 查询订单 - 按客户ID无订单 (200 OK, 空数组)
GET {{baseUrl}}/api/orders?customerId=99999

### 14. 校验库存扣减 - 下单后验证
# 将 1、2 替换为实际商品 id
GET {{baseUrl}}/api/products/1

GET {{baseUrl}}/api/products/2
